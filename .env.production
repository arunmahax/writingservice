# ============================================
# Recipe Generator - Production Configuration
# ============================================

# Environment
NODE_ENV=production

# Server Configuration
PORT=3090
LOG_LEVEL=info

# OpenRouter API Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
AI_MODEL=anthropic/claude-sonnet-4

# API Key Protection
API_KEY=your_api_key_here

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/recipe-generator
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/recipe-generator

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# For Redis Cloud: REDIS_HOST=redis-xxxxx.cloud.redislabs.com

# Queue Configuration (BullMQ)
WORKER_CONCURRENCY=2
WORKER_MAX_JOBS=10
WORKER_DURATION=60000

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100
CREATE_JOB_LIMIT=10

# CORS Configuration
CORS_ORIGIN=*

# Retry Configuration
MAX_RETRIES=10
RETRY_DELAY=5000
REQUEST_TIMEOUT=30000
