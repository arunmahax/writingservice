# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Server Configuration
PORT=3090
NODE_ENV=development

# Redis (if using - optional)
REDIS_URL=redis://localhost:6379

# Rate Limiting
MAX_CONCURRENT_JOBS=5
REQUEST_TIMEOUT=30000

# Retry Configuration
MAX_RETRIES=10
RETRY_DELAY=5000
